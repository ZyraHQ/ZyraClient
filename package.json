  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.6.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "consola": "^3.4.2",
    "discord.js": "^14.26.3",
    "zod": "^4.3.6"
  }
