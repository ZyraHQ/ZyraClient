{
  "name": "zyraclient",
  "description": "A modern and powerful library for building Discord bots with simplicity and scalability.",
  "version": "0.0.7",
  "license": "MIT",
  "keywords": [
    "discord",
    "discord-bot",
    "discordjs",
    "bot-framework",
    "bot",
    "nodejs",
    "typescript",
    "zyra",
    "zyraclient"
  ],
  "type": "module",

  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",

  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },

  "files": [
    "dist"
  ],

  "scripts": {
    "dev": "bun run --watch src/test/index.ts",

    "build": "bun build ./src/index.ts --outdir ./dist --target node && tsc -p tsconfig.build.json",

    "prepublishOnly": "npm run build",

    "release": "npm version patch && git push && git push --tags"
  },

  "repository": {
    "type": "git",
    "url": "https://github.com/ZyraHQ/zyraclient.git"
  },

  "homepage": "https://github.com/ZyraHQ/zyraclient",

  "bugs": {
    "url": "https://github.com/ZyraHQ/zyraclient/issues"
  },

  "engines": {
    "node": ">=18"
  },

  "sideEffects": false,

  "publishConfig": {
    "access": "public"
  },

  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.6.0"
  },

  "peerDependencies": {
    "typescript": "^5"
  },

  "dependencies": {
    "chalk": "^5.6.2",
    "consola": "^3.4.2",
    "discord.js": "^14.26.3",
    "zod": "^4.3.6"
  }
}