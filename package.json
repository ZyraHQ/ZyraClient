{
  "name": "zyraclient",
  "description": "A modern and powerful library for building Discord bots with simplicity and scalability.",
  "version": "0.0.8",
  "license": "MIT",
  "keywords": [
    "discord",
    "discord-bot",
    "discordjs",
    "bot-framework",
    "bot",
    "nodejs",
    "typescript",
    "zyra",
    "zyraclient"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "bun run --watch src/test/index.ts",
     "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "bun run build",
    "release": "bun run build && npm version patch && git push --follow-tags && npm publish"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ZyraHQ/zyraclient.git"
  },
  "homepage": "https://github.com/ZyraHQ/zyraclient",
  "bugs": {
    "url": "https://github.com/ZyraHQ/zyraclient/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.6.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "consola": "^3.4.2",
    "discord.js": "^14.26.3",
    "zod": "^4.3.6"
  }
}
